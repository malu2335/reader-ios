# Uncomment the next line to define a global platform for your project
platform :ios, '15.0'
inhibit_all_warnings!
target 'Reader' do
  pod 'YYModel', '~> 1.0.4'
  pod 'SDWebImage', '~> 5.6.0'
  pod 'SDWebImageWebPCoder', '~> 0.5.0'
  pod 'JLRoutes', '1.6.2'
  pod 'GBDeviceInfo', '~> 6.3.0'
  pod 'MJRefresh', '~> 3.1.14'
  pod 'WMPageController', '~> 2.5.0'
  pod 'Masonry', '~> 1.1.0'
  pod 'KVOController', '~> 1.2.0'
  pod 'MGSwipeTableCell', '~> 1.6.8'
  pod 'WCDB', '~> 1.0.7'
  pod 'YYText'
#  pod 'OHHTTPStubs'
  pod 'RDVTabBarController'
  pod 'FDFullscreenPopGesture', '1.1'
  pod 'MBProgressHUD'
  pod 'UITextView+Placeholder'

end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      # Xcode 15+ 默认开启脚本沙箱会导致 CocoaPods 脚本阶段失败
      config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
    end
  end

  # Xcode 26 clang 将链式比较判为错误，YYText 上游笔误(`<` 应为 `?`)需要修补
  yytext_layout = File.join(installer.sandbox.root.to_s, 'YYText', 'YYText', 'Component', 'YYTextLayout.m')
  if File.exist?(yytext_layout)
    content = File.read(yytext_layout)
    patched = content.gsub(/< fabs\(right - point\.([xy])\) < \(right \? prev : next\);/, '< fabs(right - point.\1) ? prev : next;')
    if patched != content
      File.chmod(0644, yytext_layout)
      File.write(yytext_layout, patched)
    end
  end

  # Xcode 26 / libc++ 对 std::list<const T> 进行严格检查，WCDB 1.x 旧代码会触发编译错误
  wcdb_root = File.join(installer.sandbox.root.to_s, 'WCDB', 'objc', 'WCDB')
  if Dir.exist?(wcdb_root)
    Dir.glob(File.join(wcdb_root, '**', '*.{h,hpp,mm,cpp}')).each do |file|
      content = File.read(file)
      patched = content.gsub(/std::list<const\s+([^>]+)>/, 'std::list<\1>')
      patched = patched.gsub(/std::initializer_list<const\s+([^>]+)>/, 'std::initializer_list<\1>')
      if patched != content
        begin
          File.chmod(0644, file)
        rescue StandardError
        end
        File.write(file, patched)
      end
    end
  end
end
